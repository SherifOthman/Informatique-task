<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.Master.cs" Inherits="Informatique_task.Site" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title></title>
    <link rel="stylesheet" type="text/css" href="~/Content/Global.css" />
    <asp:ContentPlaceHolder ID="HeadContent" runat="server">
    </asp:ContentPlaceHolder>
</head>
<body>

<form id="form1" runat="server" enctype="multipart/form-data">

<div class="navbar">
    <div class="nav-left">
        <span class="nav-brand">TaskManager</span>
        <asp:HyperLink NavigateUrl="~/Pages/Admin/Dashboard.aspx" runat="server" CssClass="nav-link">Dashboard</asp:HyperLink>
        <asp:HyperLink NavigateUrl="~/Pages/Admin/CreateTask.aspx" runat="server" CssClass="nav-link">Create Task</asp:HyperLink>
        <asp:HyperLink NavigateUrl="~/Pages/Admin/Tasks.aspx" runat="server" CssClass="nav-link">Tasks</asp:HyperLink>
    </div>
    <asp:LinkButton ID="btnLogout" runat="server" CssClass="nav-logout" OnClick="btnLogout_Click">Logout</asp:LinkButton>
</div>

<div class="content">
    <asp:ContentPlaceHolder ID="MainContent" runat="server">
    </asp:ContentPlaceHolder>
</div>

</form>

</body>
</html>
